{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Targets Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "count(infraprobe_ping_success == 1)", "legendFormat": "Up" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "title": "Targets Down",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        { "expr": "count(infraprobe_ping_success == 0)", "legendFormat": "Down" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "title": "Total Checks Performed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum(infraprobe_checks_total)", "legendFormat": "Total" }
      ]
    },
    {
      "title": "Check Failure Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(infraprobe_checks_failed_total[5m])) / sum(rate(infraprobe_checks_total[5m])) * 100", "legendFormat": "Failure %" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } }
      }
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "infraprobe_cpu_usage_percent{mode=\"total\"}", "legendFormat": "CPU" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] } }
      }
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        { "expr": "infraprobe_memory_usage_percent", "legendFormat": "Memory" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] } }
      }
    },
    {
      "title": "Ping RTT Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(infraprobe_ping_rtt_seconds_bucket[5m]))", "legendFormat": "p50 {{ target }}" },
        { "expr": "histogram_quantile(0.95, rate(infraprobe_ping_rtt_seconds_bucket[5m]))", "legendFormat": "p95 {{ target }}" },
        { "expr": "histogram_quantile(0.99, rate(infraprobe_ping_rtt_seconds_bucket[5m]))", "legendFormat": "p99 {{ target }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "HTTP Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(infraprobe_http_response_seconds_bucket[5m]))", "legendFormat": "p95 {{ url }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Packet Loss",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "infraprobe_ping_packet_loss_ratio * 100", "legendFormat": "{{ target }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "title": "TLS Certificate Expiry (Days)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "infraprobe_tls_days_until_expiry", "legendFormat": "{{ hostname }}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "d", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 }] } }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infraprobe", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "InfraProbe Overview",
  "uid": "infraprobe-overview"
}
