# =============================================================================
# InfraProbe Configuration - Managed by Ansible
# =============================================================================
# Template: roles/infraprobe/templates/config.yml.j2
# Do not edit this file directly on the server. Changes will be overwritten
# on the next Ansible deployment.
# =============================================================================

targets:
{% for target in infraprobe_targets %}
  - name: "{{ target.name }}"
    host: "{{ target.host }}"
    checks:
{% for check in target.checks %}
      - type: {{ check.type }}
{% if check.type == 'ping' %}
        interval: {{ check.interval | default(30) }}
        timeout: {{ check.timeout | default(5) }}
        count: {{ check.count | default(3) }}
{% elif check.type == 'http' %}
        url: "{{ check.url }}"
        expected_status: {{ check.expected_status | default(200) }}
        check_tls: {{ check.check_tls | default(true) | lower }}
        interval: {{ check.interval | default(60) }}
        timeout: {{ check.timeout | default(10) }}
{% elif check.type == 'tcp' %}
        ports: {{ check.ports | to_json }}
        interval: {{ check.interval | default(120) }}
        timeout: {{ check.timeout | default(5) }}
{% elif check.type == 'dns' %}
        domain: "{{ check.domain }}"
        record_type: {{ check.record_type | default('A') }}
        interval: {{ check.interval | default(60) }}
{% endif %}
{% endfor %}

{% endfor %}

system:
  enabled: {{ infraprobe_system_metrics.enabled | default(true) | lower }}
  collect_cpu: {{ infraprobe_system_metrics.collect_cpu | default(true) | lower }}
  collect_memory: {{ infraprobe_system_metrics.collect_memory | default(true) | lower }}
  collect_disk: {{ infraprobe_system_metrics.collect_disk | default(true) | lower }}
  collect_processes: {{ infraprobe_system_metrics.collect_processes | default(true) | lower }}
  collect_sockets: {{ infraprobe_system_metrics.collect_sockets | default(true) | lower }}
  disk_paths:
{% for path in infraprobe_system_metrics.disk_paths | default(['/']) %}
    - "{{ path }}"
{% endfor %}
  interval: {{ infraprobe_system_metrics.interval | default(15) }}

logging:
  level: {{ infraprobe_log_level | default('INFO') }}
  format: {{ infraprobe_log_format | default('json') }}
  file: {{ infraprobe_log_dir }}/infraprobe.log

alerting:
  rules:
{% for rule in infraprobe_alerting_rules | default([]) %}
    - name: "{{ rule.name }}"
      metric: "{{ rule.metric }}"
      condition: "{{ rule.condition }}"
      duration: "{{ rule.duration }}"
      severity: {{ rule.severity }}
      notify: ["webhook"]
{% endfor %}

  notifiers:
    webhook:
      url: "{{ infraprobe_webhook_url | default('') }}"
      timeout: {{ infraprobe_webhook_timeout | default(10) }}

metrics:
  enabled: true
  port: {{ infraprobe_metrics_port }}
  bind: "{{ infraprobe_metrics_bind | default('0.0.0.0') }}"
