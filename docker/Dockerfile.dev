# InfraProbe — Development Dockerfile
# Includes dev tools, hot-reloading, and debugging support.

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    iputils-ping \
    net-tools \
    dnsutils \
    traceroute \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install all dependencies including dev extras
COPY pyproject.toml README.md LICENSE ./
COPY src/ src/
RUN pip install --no-cache-dir -e ".[dev]"

# Copy test files
COPY tests/ tests/
COPY Makefile ./

EXPOSE 9100

CMD ["infraprobe", "serve", "--port", "9100"]
